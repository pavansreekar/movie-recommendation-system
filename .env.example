# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at https://developer.themoviedb.org/docs/getting-started
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Claude / Anthropic — powers the in-app chat assistant
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Flask ─────────────────────────────────────────────────────────────────────
# Change to a long random string in production: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-secret-change-me-in-production

# ── CORS / origins ────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the Flask API
# In production add your Vercel URL, e.g. https://your-app.vercel.app
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Next.js → Flask proxy ─────────────────────────────────────────────────────
# Used by next.config.mjs rewrites; set to your Render/Railway backend URL in prod
BACKEND_ORIGIN=http://localhost:5001

# ── TMDB tuning (optional) ────────────────────────────────────────────────────
TMDB_TIMEOUT_SECONDS=5
TMDB_MAX_RETRIES=2
